# VendorBridge Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=change_me_to_a_strong_random_secret
# IMPORTANT: Replace `JWT_SECRET` with a strong, unguessable value (recommended: 32+ random characters).
# Do NOT commit real secrets to source control; use a secrets manager or CI/CD env settings.

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vendorbridge

# Email (mock mode - set MOCK_EMAIL=true to skip real sending)
MOCK_EMAIL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Client
VITE_API_URL=http://localhost:5000/api
# Optional: Vite-only demo password used by the local dev UI for quick logins.
# Set this only for local development (do NOT set in production).
VITE_DEMO_PASSWORD=Password123!
